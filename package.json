{
  "name": "reycoelectric",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build:css": "postcss assets/css/main.css -o assets/css/output.css",
    "watch:css": "postcss assets/css/main.css -o assets/css/output.css --watch",
    "dev": "concurrently \"npm run watch:css\" \"bundle exec jekyll serve --livereload\"",
    "build": "NODE_ENV=production npm run build:css && bundle exec jekyll build"
  },
  "devDependencies": {
    "@tailwindcss/forms": "^0.5.7",
    "@tailwindcss/typography": "^0.5.13",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "postcss": "^8.4.38",
    "postcss-cli": "^11.0.0",
    "tailwindcss": "^3.4.4"
  }
}
